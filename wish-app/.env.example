# ──────────────────────────────────────────────────────────────
# Environment Variables for wish-app
#
# SETUP:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in your real values below
#   3. Run:  docker compose up --build
#
# NOTE: .env is gitignored — your secrets stay on your machine.
# ──────────────────────────────────────────────────────────────

# ── Supabase (public — safe to expose in browser) ───────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Supabase (secret — server-side only) ────────────────────
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Upstash Redis (managed Redis, used for caching) ─────────
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Gemini AI ────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ── Admin ────────────────────────────────────────────────────
ADMIN_CODE=your-admin-code
